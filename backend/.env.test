APP_ENV=test
APP_SECRET=test_secret_key

DATABASE_URL="postgresql://busexpress:busexpress_secret@localhost:5432/busexpress_test?serverVersion=16&charset=utf8"

MESSENGER_TRANSPORT_DSN=in-memory://

REDIS_HOST=localhost
REDIS_PORT=6379

