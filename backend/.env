APP_ENV=dev
APP_SECRET=busexpress_super_secret_key_change_in_prod

DATABASE_URL="postgresql://busexpress:busexpress_secret@postgres:5432/busexpress?serverVersion=16&charset=utf8"

MESSENGER_TRANSPORT_DSN=amqp://busexpress:busexpress_secret@rabbitmq:5672/busexpress/messages

REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=busexpress_jwt

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
